---
import { getCollection, getEntry } from 'astro:content';
import { twJoin } from 'tailwind-merge';

import Layout from '~/layouts/Layout.astro';
import IconLinks from '~/components/IconLinks.astro';
import Link from '~/components/Link.astro';
import ProjectItem from '~/components/ProjectItem.astro';

const portfolioItems = await getCollection('projects');
---

<Layout>
	<div class:list={['flex flex-col', 'lg:h-screen lg:flex-row lg:overflow-hidden']}>
		<!-- Sidebar -->
		<div class:list={['flex h-[75svh] flex-col gap-6', 'p-12 lg:h-full lg:p-6']}>
			<div class="flex flex-col gap-2 text-balance">
				<h1 class:list={['font-[550] tracking-tight', 'animate-fade-in-slide animation-delay-100']}>
					Nikita Pashinsky
				</h1>
				<p
					class:list={[
						'font-[450] tracking-tight text-neutral-600',
						'animate-fade-in-slide animation-delay-150',
					]}
				>
					I'm a product designer focused on crafting high-quality software. Currently leading
					product design on Composer at <Link href="https://piano.io" external>Piano</Link>.
				</p>
			</div>
			<IconLinks />
		</div>

		<!-- Projects -->
		<div
			class:list={[
				'flex flex-col items-center overflow-y-scroll overscroll-contain',
				'p-3 sm:p-4 lg:p-6',
				'gap-3 sm:gap-4 lg:gap-6',
			]}
		>
			{portfolioItems.map((item) => <ProjectItem project={item.data} />)}
		</div>
	</div>
</Layout>

---
import { twMerge } from 'tailwind-merge';
import Icon from './Icons.astro';

const links = [
	{ label: 'Email', url: 'mailto:n@nkta.me', icon: 'email' as const },
	{ label: 'Twitter', url: 'https://twitter.com/nikitapashinsky', icon: 'twitter' as const },
	{ label: 'Bluesky', url: 'https://bsky.app/profile/nkta.me', icon: 'bluesky' as const },
	{ label: 'Github', url: 'https://github.com/nikitapashinsky', icon: 'github' as const },
	{ label: 'Are.na', url: 'https://www.are.na/nikita-pashinsky', icon: 'arena' as const },
];
---

<ul class="-ml-3 flex md:-ml-2.5">
	{
		links.map(({ icon, label, url }, index) => (
			<li
				style={`--delay: ${index * 50 + 250}ms`}
				class="animate-fade-in-slide animation-delay-(--delay)"
			>
				<a
					href={url}
					aria-label={label}
					target="_blank"
					rel="noopener noreferrer"
					class:list={[
						'group relative flex items-center justify-center px-3 py-2 md:px-2.5',
						'transition-transform will-change-transform active:scale-95',
						'outline-none',
						'before:pointer-events-none before:absolute before:inset-x-1 before:inset-y-0 before:-z-1 before:rounded-md md:before:inset-x-0.5',
						'before:bg-neutral-100/0 before:will-change-transform',
						'before:transition-colors before:duration-125',
						'hover:before:bg-neutral-100 hover:before:duration-75 active:before:bg-neutral-100 active:before:duration-75',
						'before:outline-neutral-300 focus-visible:before:outline',
					]}
				>
					<Icon
						icon={icon}
						class:list={[
							'size-5 fill-neutral-450 transition-colors duration-125 group-hover:fill-black group-hover:duration-75 group-focus-visible:fill-black group-focus-visible:duration-75 group-active:fill-black group-active:duration-75',
						]}
					/>
				</a>
			</li>
		))
	}
</ul>

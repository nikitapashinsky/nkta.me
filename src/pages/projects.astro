---
import Layout from "@/layouts/Layout.astro";
import { twJoin } from "tailwind-merge";
import { GithubIcon } from "@/components/react/icons";
import Link from "@/components/Link.astro";
import ZedLogo from "@/assets/images/logos/zed.svg";
import zoegiDarkScreenshot from "@/assets/images/projects/zoegi-dark-base-ui.webp";
---

<Layout title="Projects · Nikita Pashinsky ">
  <div
    class={twJoin(
      "col-span-full row-start-2",
      "grid grid-cols-subgrid content-start gap-x-4 gap-y-12",
    )}
  >
    <div class={"col-span-full flex flex-col gap-2"}>
      <h1 class={"text-xl md:text-2xl"}>Projects</h1>
    </div>

    <div class={"col-span-full flex flex-col gap-6 md:col-span-5"}>
      <img
        src={zoegiDarkScreenshot.src}
        alt="Zoegi Dark theme for Zed code editor"
        width={980}
        height={615}
        class={"h-auto w-full rounded-xs bg-neutral-100 shadow-lg dark:bg-neutral-900"}
      />
      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <h3>Zoegi theme</h3>
          <p class="text-balance text-secondary">
            A visually pleasing and polished theme for Zed based on the
            beautiful Moegi theme for VS Code.
          </p>
        </div>
        <div class="flex items-center gap-6">
          <Link
            href="zed://extension/zoegi-theme"
            class="group flex items-center gap-1.5"
          >
            <ZedLogo
              class="size-5 fill-neutral-450 group-hover:fill-[#1348DC] group-active:fill-[#1348DC]"
            />
            Install in Zed
          </Link>
          <Link
            href="https://github.com/nikitapashinsky/zoegi-theme"
            class="group flex items-center gap-1.5"
          >
            <GithubIcon
              className="size-5 fill-neutral-450 group-hover:fill-neutral-950 group-active:fill-neutral-950"
            />
            Github
          </Link>
        </div>
      </div>
    </div>
  </div>
</Layout>
